{
  "rust-analyzer.linkedProjects": ["apps/spanwork/src-tauri/Cargo.toml"],
  "rust-analyzer.cargo.buildScripts.enable": true,
  "rust-analyzer.procMacro.enable": true,
  "rust-analyzer.check.command": "clippy",
  "files.watcherExclude": {
    "**/target/**": true,
    "**/node_modules/**": true,
    "**/.pnpm-store/**": true,
    "**/dist/**": true
  },
  "search.exclude": {
    "**/target": true,
    "**/node_modules": true,
    "**/.pnpm-store": true,
    "**/dist": true
  }
}
